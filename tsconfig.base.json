{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@job-tracker-lite-angular/api-interfaces": [
        "./libs/api-interfaces/src/index.ts"
      ],
      "@job-tracker-lite-angular/frontend-data-access": [
        "./libs/frontend/src/index.ts"
      ],
      "@job-tracker-lite-angular/prisma": [
        "./libs/shared/prisma/src/index.ts"
      ],
      "spartan/ui/helm": [
        "./libs/shared-ui/card/src/index.ts"
      ],
      "@shared-ui/helm/card": [
        "./libs/shared-ui/card/src/index.ts"
      ],
      "@shared-ui/helm/utils": [
        "./libs/shared-ui/utils/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
