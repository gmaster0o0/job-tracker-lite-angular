{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@job-tracker-lite-angular/api-interfaces": [
        "./libs/api-interfaces/src/index.ts"
      ],
      "@job-tracker-lite-angular/frontend-data-access": [
        "./libs/frontend/src/index.ts"
      ],
      "@job-tracker-lite-angular/prisma": [
        "./libs/shared/prisma/src/index.ts"
      ],
      "spartan/ui/helm": [
        "./libs/shared-ui/card/src/index.ts"
      ],
      "@shared-ui/helm/card": [
        "./libs/shared-ui/card/src/index.ts"
      ],
      "@shared-ui/helm/utils": [
        "./libs/shared-ui/utils/src/index.ts"
      ],
      "@shared-ui/helm/sidebar": [
        "./libs/shared-ui/sidebar/src/index.ts"
      ],
      "@shared-ui/helm/sidebar/*": [
        "./libs/shared-ui/sidebar/src/lib/*"
      ],
      "@shared-ui/helm/button": [
        "./libs/shared-ui/button/src/index.ts"
      ],
      "@shared-ui/helm/icon": [
        "./libs/shared-ui/icon/src/index.ts"
      ],
      "@shared-ui/helm/input": [
        "./libs/shared-ui/input/src/index.ts"
      ],
      "@shared-ui/helm/separator": [
        "./libs/shared-ui/separator/src/index.ts"
      ],
      "@shared-ui/helm/sheet": [
        "./libs/shared-ui/sheet/src/index.ts"
      ],
      "@shared-ui/helm/skeleton": [
        "./libs/shared-ui/skeleton/src/index.ts"
      ],
      "@shared-ui/helm/tooltip": [
        "./libs/shared-ui/tooltip/src/index.ts"
      ],
      "@shared-ui/helm/badge": [
        "./libs/shared-ui/badge/src/index.ts"
      ],
      "@shared-ui/helm/breadcrumb": [
        "./libs/shared-ui/breadcrumb/src/index.ts"
      ],
      "@shared-ui/helm/spinner": [
        "./libs/shared-ui/spinner/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
