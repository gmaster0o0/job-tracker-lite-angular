{
  "name": "@job-tracker-lite-angular/source",
  "version": "0.3.4",
  "license": "MIT",
  "scripts": {
    "app": "npx nx run-many --target=serve --projects=api,frontend --parallel=2 --no-tui",
    "prepare": "husky install",
    "prepare:dev": "npm run prisma:generate",
    "prisma:generate": "npx prisma generate --schema=libs/shared/prisma/db-schema/schema.prisma",
    "db:migrate": "cd libs/shared/prisma && npx prisma migrate dev",
    "db:migrate:deploy": "cd libs/shared/prisma && npx prisma migrate deploy",
    "db:push": "cd libs/shared/prisma && npx prisma db push",
    "commitlint": "npx commitlint --from=HEAD~1 --to=HEAD",
    "db:seed": "npx nx run prisma:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "test": "npx nx run-many --target=test --all",
    "lint": "npx nx run-many --target=lint --all",
    "typecheck": "npx nx run-many --target=typecheck --all",
    "test:push": "npx nx affected -t test --base=origin/main --head=HEAD --parallel=3",
    "release": "npx standard-version && node tools/sync-version.js && git add . && git commit --amend --no-edit",
    "i18n:extract": "npx transloco-keys-manager extract --config libs/frontend/src/lib/transloco/transloco.config.ts --project frontend --input \"apps/frontend/src,libs/frontend/src\" --translations-path \"./apps/frontend/public/assets/i18n/\"",
    "i18n:find": "npx transloco-keys-manager find --config libs/frontend/src/lib/transloco/transloco.config.ts --project frontend --input \"apps/frontend/src,libs/frontend/src\" --translations-path \"./apps/frontend/public/assets/i18n/\""
  },
  "private": true,
  "engines": {
    "node": ">=22.22.1"
  },
