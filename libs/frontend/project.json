{
  "name": "data-access",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/frontend/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/frontend/ng-package.json",
        "tsConfig": "libs/frontend/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/frontend/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck-lib": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit --pretty -p libs/frontend/tsconfig.lib.json",
        "forwardAllArgs": false
      }
    },
    "typecheck-spec": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit --pretty -p libs/frontend/tsconfig.spec.json",
        "forwardAllArgs": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run data-access:typecheck-lib",
          "nx run data-access:typecheck-spec"
        ],
        "parallel": true
      }
    }
  }
}
