generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  JOB_OFFERED
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
}

model Job {
  id          Int       @id @default(autoincrement())
  position    String
  link        String    @unique
  description String
  company     String
  status      JobStatus @default(SAVED)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}