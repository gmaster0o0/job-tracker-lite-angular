generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  JOB_OFFERED
  REJECTED
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
}

model Job {
  id          Int       @id @default(autoincrement())
  position    String
  link        String    @unique
  description String
  company     String
  status      JobStatus @default(SAVED)
  contacts    Contact[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Contact {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  phoneNumber String
  jobId       Int
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}