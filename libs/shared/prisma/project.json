{
  "name": "prisma",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/prisma/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma generate --schema=libs/shared/prisma/db-schema/schema.prisma"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/prisma",
        "tsConfig": "libs/shared/prisma/tsconfig.lib.json",
        "packageJson": "libs/shared/prisma/package.json",
        "main": "libs/shared/prisma/src/index.ts",
        "assets": ["libs/shared/prisma/*.md"]
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node -r tsconfig-paths/register --project libs/shared/prisma/tsconfig.json libs/shared/prisma/src/seed.ts"
      }
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma migrate dev --schema=libs/shared/prisma/db-schema/schema.prisma"
      }
    },
    "migrate-deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma migrate deploy --schema=libs/shared/prisma/db-schema/schema.prisma"
      }
    },
    "db-push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma db push --schema=libs/shared/prisma/db-schema/schema.prisma"
      }
    },
    "typecheck-lib": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit --pretty -p libs/shared/prisma/tsconfig.lib.json"
      }
    },
    "typecheck-spec": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit --pretty -p libs/shared/prisma/tsconfig.spec.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run prisma:typecheck-lib",
          "nx run prisma:typecheck-spec"
        ],
        "parallel": true
      }
    }
  }
}
