{
  "name": "prisma",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/prisma/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma generate --schema=libs/shared/prisma/db-schema/schema.prisma && node -e \"const fs=require('fs');const src='libs/shared/prisma/node_modules/.prisma/client';const dst='node_modules/.prisma/client';if(fs.existsSync(src)){fs.mkdirSync('node_modules/.prisma',{recursive:true});fs.rmSync(dst,{recursive:true,force:true});fs.cpSync(src,dst,{recursive:true});}\""
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/prisma",
        "tsConfig": "libs/shared/prisma/tsconfig.lib.json",
        "packageJson": "libs/shared/prisma/package.json",
        "main": "libs/shared/prisma/src/index.ts",
        "assets": ["libs/shared/prisma/*.md"]
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --project libs/shared/prisma/tsconfig.json libs/shared/prisma/src/seed.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc -p libs/shared/prisma/tsconfig.lib.json --noEmit"
      }
    }
  }
}
