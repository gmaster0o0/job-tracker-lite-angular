{
  "name": "api-interfaces",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/api-interfaces/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/api-interfaces",
        "main": "libs/api-interfaces/src/index.ts",
        "tsConfig": "libs/api-interfaces/tsconfig.lib.json",
        "assets": ["libs/api-interfaces/*.md"]
      }
    },
    "typecheck-lib": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit --pretty -p libs/api-interfaces/tsconfig.lib.json"
      }
    },
    "typecheck-spec": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit --pretty -p libs/api-interfaces/tsconfig.spec.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run api-interfaces:typecheck-lib",
          "nx run api-interfaces:typecheck-spec"
        ],
        "parallel": true
      }
    }
  }
}
